# Supabase — get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Postgres connection string (use the pooler/pgBouncer URL for serverless)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Resend — for transactional email (match verification notifications)
RESEND_API_KEY=re_your_api_key

# App URL — used for building absolute URLs in emails
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Admin user ID — the Supabase Auth UUID of the admin account
NEXT_PUBLIC_ADMIN_USER_ID=your-supabase-user-uuid
