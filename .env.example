# Supabase — get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Postgres connection string (use the pooler/pgBouncer URL for serverless)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# App URL — used for building absolute URLs in emails
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Admin user IDs — Supabase Auth UUIDs with admin access
# Prefer the private vars below (not exposed to client bundle). The NEXT_PUBLIC_
# variants are kept for the navbar's cosmetic UI check only.
ADMIN_USER_ID=your-supabase-user-uuid
ADMIN_USER_ID_2=second-admin-supabase-uuid
NEXT_PUBLIC_ADMIN_USER_ID=your-supabase-user-uuid
NEXT_PUBLIC_ADMIN_USER_ID_2=second-admin-supabase-uuid
